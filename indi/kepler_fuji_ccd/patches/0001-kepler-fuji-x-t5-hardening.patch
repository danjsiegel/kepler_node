+int gphoto_read_focus_position(gphoto_driver *gphoto, int *value, char *errMsg)
+{
+    CameraWidget *widget = nullptr, *child = nullptr;
+    CameraWidgetType type;
+    const char *current = nullptr;
+    char *end = nullptr;
+    long parsed = 0;
+    float numeric = 0;
+    int ret;
+
+    if (gphoto == nullptr || value == nullptr || gphoto->focus_widget == nullptr)
+    {
+        snprintf(errMsg, MAXRBUF, "focus widget is unavailable");
+        return GP_ERROR_BAD_PARAMETERS;
+    }
+
+    ret = gp_camera_get_config(gphoto->camera, &widget, gphoto->context);
+    if (ret < GP_OK)
+    {
+        snprintf(errMsg, MAXRBUF, "camera_get_config failed: %d", ret);
+        return ret;
+    }
+
+    ret = _lookup_widget(widget, gphoto->focus_widget->name, &child);
+    if (ret < GP_OK)
+    {
+        snprintf(errMsg, MAXRBUF, "lookup '%s' failed: %d", gphoto->focus_widget->name, ret);
+        goto out_focus_read;
+    }
+
+    ret = gp_widget_get_type(child, &type);
+    if (ret < GP_OK)
+    {
+        snprintf(errMsg, MAXRBUF, "widget get type failed: %d", ret);
+        goto out_focus_read;
+    }
+
+    if (type == GP_WIDGET_RANGE)
+    {
+        ret = gp_widget_get_value(child, &numeric);
+        if (ret < GP_OK)
+            snprintf(errMsg, MAXRBUF, "could not get range focus value: %d", ret);
+        else
+            *value = static_cast<int>(numeric);
+        goto out_focus_read;
+    }
+
+    if (type != GP_WIDGET_TEXT && type != GP_WIDGET_RADIO && type != GP_WIDGET_MENU)
+    {
+        snprintf(errMsg, MAXRBUF, "unsupported focus widget type: %d", type);
+        ret = GP_ERROR_NOT_SUPPORTED;
+        goto out_focus_read;
+    }
+
+    ret = gp_widget_get_value(child, &current);
+    if (ret < GP_OK || current == nullptr)
+    {
+        snprintf(errMsg, MAXRBUF, "could not get text focus value: %d", ret);
+        goto out_focus_read;
+    }
+
+    parsed = strtol(current, &end, 10);
+    if (end == current || (end != nullptr && *end != '\0'))
+    {
+        snprintf(errMsg, MAXRBUF, "non-numeric focus value: %s", current);
+        ret = GP_ERROR_BAD_PARAMETERS;
+        goto out_focus_read;
+    }
+
+    *value = static_cast<int>(parsed);
+    ret = GP_OK;
+
+out_focus_read:
+    gp_widget_free(widget);
+    return ret;
+}
