+static bool is_fuji_camera(const gphoto_driver *gphoto)
+{
+    return gphoto && gphoto->manufacturer && strcasestr(gphoto->manufacturer, "Fuji") != nullptr;
+}
+
+static void discard_fuji_pending_file(gphoto_driver *gphoto, const CameraFilePath *path, const char *reason)
+{
+    if (!is_fuji_camera(gphoto) || path == nullptr || path->folder[0] == '\0' || path->name[0] == '\0')
+        return;
+
+    int result = gp_camera_file_delete(gphoto->camera, path->folder, path->name, gphoto->context);
+    if (result == GP_OK)
+    {
+        DEBUGFDEVICE(device, INDI::Logger::DBG_SESSION,
+                     "Discarded pending Fuji file after %s: %s/%s", reason, path->folder, path->name);
+    }
+    else if (result != GP_ERROR_FILE_NOT_FOUND)
+    {
+        DEBUGFDEVICE(device, INDI::Logger::DBG_WARNING,
+                     "Failed to discard pending Fuji file after %s: %s/%s (%s)", reason, path->folder, path->name,
+                     gp_result_as_string(result));
+    }
+}
+
+static void drain_fuji_pending_events(gphoto_driver *gphoto, const char *reason)
+{
+    if (!is_fuji_camera(gphoto))
+        return;
+
+    for (int attempt = 0; attempt < 5; ++attempt)
+    {
+        CameraEventType event = GP_EVENT_UNKNOWN;
+        void *data = nullptr;
+        int result = gp_camera_wait_for_event(gphoto->camera, 100, &event, &data, gphoto->context);
+
+        if (result != GP_OK || event == GP_EVENT_TIMEOUT)
+            break;
+
+        if (event == GP_EVENT_FILE_ADDED)
+            discard_fuji_pending_file(gphoto, static_cast<CameraFilePath *>(data), reason);
+    }
+}
+
+static void attempt_fuji_session_recovery(gphoto_driver *gphoto, const char *reason)
+{
+    if (!is_fuji_camera(gphoto))
+        return;
+
+    DEBUGFDEVICE(device, INDI::Logger::DBG_WARNING, "Attempting Fuji session recovery after %s.", reason);
+
+    int result = gp_camera_exit(gphoto->camera, gphoto->context);
+    if (result != GP_OK)
+        DEBUGFDEVICE(device, INDI::Logger::DBG_WARNING, "Fuji session shutdown during recovery failed: %s", gp_result_as_string(result));
+
+    usleep(500000);
+
+    result = gp_camera_init(gphoto->camera, gphoto->context);
+    if (result != GP_OK)
+        DEBUGFDEVICE(device, INDI::Logger::DBG_ERROR, "Fuji session recovery failed: %s", gp_result_as_string(result));
+    else
+    {
+        discard_fuji_pending_file(gphoto, &gphoto->camerapath, reason);
+        drain_fuji_pending_events(gphoto, reason);
+        DEBUGDEVICE(device, INDI::Logger::DBG_SESSION, "Fuji session recovery succeeded.");
+    }
+}
