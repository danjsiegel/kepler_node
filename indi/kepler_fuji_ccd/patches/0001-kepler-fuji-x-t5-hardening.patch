+bool GPhotoCCD::refreshFujiFocusState()
+{
+    if (!is_kepler_fuji_driver() || gphotodrv == nullptr)
+        return false;
+
+    int rawPosition = 0;
+    char errMsg[MAXRBUF] = {0};
+    if (gphoto_read_focus_position(gphotodrv, &rawPosition, errMsg) != GP_OK)
+    {
+        LOGF_ERROR("Failed to read Fuji d171 focus position: %s", errMsg);
+        return false;
+    }
+
+    m_FujiFocusRawCurrent = rawPosition;
+    if (!m_HaveFujiFocusState)
+    {
+        m_FujiFocusMinRaw = rawPosition;
+        m_FujiFocusMaxRaw = rawPosition;
+    }
+    else
+    {
+        m_FujiFocusMinRaw = std::min(m_FujiFocusMinRaw, rawPosition);
+        m_FujiFocusMaxRaw = std::max(m_FujiFocusMaxRaw, rawPosition);
+    }
+
+    m_HaveFujiFocusState = true;
+    FocusAbsPosN[0].value = fujiRawToAbsoluteTicks(rawPosition);
+    return true;
+}
+
+uint32_t GPhotoCCD::fujiRawToAbsoluteTicks(int32_t rawTicks) const
+{
+    const int32_t biasedTicks = rawTicks + FUJI_D171_ABS_BIAS;
+    if (biasedTicks < 0)
+        return 0;
+    if (biasedTicks > static_cast<int32_t>(FUJI_D171_ABS_MAX))
+        return FUJI_D171_ABS_MAX;
+    return static_cast<uint32_t>(biasedTicks);
+}
+
+int32_t GPhotoCCD::fujiAbsoluteToRawTicks(uint32_t absoluteTicks) const
+{
+    if (absoluteTicks > FUJI_D171_ABS_MAX)
+        absoluteTicks = FUJI_D171_ABS_MAX;
+    return static_cast<int32_t>(absoluteTicks) - FUJI_D171_ABS_BIAS;
+}
+
+IPState GPhotoCCD::MoveAbsFocuser(uint32_t targetTicks)
+{
+    if (!is_kepler_fuji_driver() || !m_CanFocus || isSimulation())
+        return IPS_ALERT;
+
+    const int FUJI_D171_SETTLE_POLL_US = 200000;
+    const int FUJI_D171_SETTLE_MAX_POLLS = 25;
+    const int FUJI_D171_SETTLE_TOLERANCE = 1;
+    const int FUJI_D171_SUCCESS_TOLERANCE = 8;
+    const int32_t targetRaw = fujiAbsoluteToRawTicks(targetTicks);
+    char errMsg[MAXRBUF] = {0};
+    if (gphoto_manual_focus(gphotodrv, targetRaw, errMsg) != GP_OK)
+    {
+        LOGF_ERROR("Fuji absolute focus move failed: %s", errMsg);
+        return IPS_ALERT;
+    }
+
+    int stableReads = 0;
+    int32_t settleA = 0;
+    int32_t settleB = 0;
+    int32_t settleC = 0;
+    for (int poll = 0; poll < FUJI_D171_SETTLE_MAX_POLLS; ++poll)
+    {
+        if (!refreshFujiFocusState())
+            return IPS_ALERT;
+
+        settleA = settleB;
+        settleB = settleC;
+        settleC = m_FujiFocusRawCurrent;
+
+        if (poll == 0)
+            stableReads = 1;
+        else if (std::abs(settleC - settleB) <= FUJI_D171_SETTLE_TOLERANCE)
+            ++stableReads;
+        else
+            stableReads = 1;
+
+        if (stableReads >= 3)
+            break;
+
+        usleep(FUJI_D171_SETTLE_POLL_US);
+    }
+
+    if (stableReads < 3)
+    {
+        LOGF_ERROR("Fuji d171 failed to settle after %d polls", FUJI_D171_SETTLE_MAX_POLLS);
+        return IPS_ALERT;
+    }
+
+    const int32_t settledLow = std::min(settleA, std::min(settleB, settleC));
+    const int32_t settledHigh = std::max(settleA, std::max(settleB, settleC));
+    const int32_t settledMedian = settleA + settleB + settleC - settledLow - settledHigh;
+    m_FujiFocusRawCurrent = settledMedian;
+    FocusAbsPosN[0].value = fujiRawToAbsoluteTicks(settledMedian);
+
+    if (std::abs(settledMedian - targetRaw) > FUJI_D171_SUCCESS_TOLERANCE)
+    {
+        LOGF_ERROR("Fuji d171 settled at raw %d outside tolerance band from requested raw %d", settledMedian, targetRaw);
+        return IPS_ALERT;
+    }
+
+    FocusAbsPosNP.s = IPS_OK;
+    IDSetNumber(&FocusAbsPosNP, nullptr);
+    LOGF_DEBUG("Fuji d171 requested raw %d, settled at raw %d", targetRaw, m_FujiFocusRawCurrent);
+    return IPS_OK;
+}
